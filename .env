# 🚀 Google Gemini Configuration (REQUIRED)
# -------------------------------------------
# Get your API key from: https://aistudio.google.com/api-keys    
GOOGLE_API_KEY=AIzaSyBFSQ6LlKJZEX400fJU4A98mFpp-Nqfg44
GEMINI_MODEL=gemini-2.0-flash
DB_PATH=./data/conversations.db

# 💾 Database Configuration
# -------------------------------------------
DB_PATH=./data/conversations.db
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# 🌐 Network Device Defaults
# -------------------------------------------
# Default device for testing (Cisco IOS)
DEFAULT_DEVICE_HOSTNAME=172.0.0.1
DEFAULT_DEVICE_TYPE=cisco_ios
DEFAULT_DEVICE_USERNAME=admin
DEFAULT_DEVICE_PORT=22

# ⚠️  WARNING: Never commit real passwords to git!
# Use a secrets manager in production
DEFAULT_DEVICE_PASSWORD=123456
DEFAULT_DEVICE_SECRET=123456

# 📡 Additional Devices (comma-separated)
# Format: name:hostname:device_type:username
ADDITIONAL_DEVICES=core:10.0.0.1:cisco_ios:netadmin,access:10.0.1.1:cisco_ios:netadmin

# 🔐 SSH Configuration
SSH_TIMEOUT=60
SSH_AUTH_TIMEOUT=30
SSH_KEEPALIVE=5

# 📝 Logging Configuration
# -------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
LOG_FORMAT=json  # json or text
LOG_MAX_BYTES=10485760  # 10MB
LOG_BACKUP_COUNT=5

# ⚡ Performance Tuning
# -------------------------------------------
MAX_CONCURRENT_TASKS=5
TASK_TIMEOUT=120  # seconds
CACHE_TTL=300  # seconds

# 🔔 Notification Settings (Optional)
# -------------------------------------------
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
EMAIL_NOTIFICATIONS=false
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
